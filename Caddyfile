tic-tac-toe-api.johnvesslyalti.xyz {
    # Compress responses for better performance
    encode gzip

    # Route authentication, health checks, and the home page to the Node server
    # Note: We use 'handle' (not 'handle_path') to keep the prefixes intact
    handle /auth/* /health / {
        reverse_proxy node-app:5000
    }

    # Route everything else to Nakama (API, Dashboard, and WebSockets)
    handle {
        reverse_proxy nakama:7350
    }
}
